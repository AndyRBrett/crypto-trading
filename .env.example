# Copy to .env and fill in. The .env file is gitignored — never commit real keys.

# Coinbase Developer Platform (Advanced Trade) API key + secret.
# Only needed if data_source is "coinbase_advanced". The api_secret for CDP
# keys is a multi-line PEM; wrap it in quotes and keep the \n escapes, e.g.:
#   COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Anthropic API key for Claude-powered trade explanations.
# Without it, the bot still trades and uses a templated explanation.
ANTHROPIC_API_KEY=

# GitHub token to publish the dashboard to GitHub Pages (view it on your phone).
# Only needed if publish_enabled: true. Use a fine-grained personal access token
# scoped to this repo with Contents: read and write.
GITHUB_TOKEN=

# Web Push notifications through the dashboard PWA (no extra app needed).
# Click the 🔔 bell in the dashboard, allow notifications, copy the JSON shown,
# then paste it here (or add it as a GitHub Actions secret PUSH_SUBSCRIPTION).
PUSH_SUBSCRIPTION=
# Generated VAPID private key — keep this secret. Add as VAPID_PRIVATE_KEY secret.
VAPID_PRIVATE_KEY=bKgEBxRtFXNF4W9GKFqDN1IKpdATeUm52fM9A9RWH4E
